{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "qwew",
  "version": "1.0.0",
  "identifier": "com.qwew.qwew-frontend",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "qwew",
        "width": 900,
        "height": 620,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "compression": "lzma",
        "languages": ["English"],
        "displayLanguageSelector": false
      }
    }
  }
}
